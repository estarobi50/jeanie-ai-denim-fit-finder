ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Shared token the frontend sends on /api/claude calls, checked server-side.
# Not a real secret (it ships in the client JS bundle) — it just raises the
# bar against naive bots hitting the endpoint without ever loading the page.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
JEANIE_SITE_KEY=REPLACE_WITH_RANDOM_VALUE
REACT_APP_JEANIE_SITE_KEY=REPLACE_WITH_SAME_RANDOM_VALUE

# Only needed if your CloudFront distribution is enrolled in a flat-rate
# pricing plan (Free/Pro/Business/Premium) via the console — those require a
# Web ACL to stay associated permanently. Find yours with:
#   aws cloudfront get-distribution-config --id <ID> --query DistributionConfig.WebACLId
# Leave unset if you're on standard pay-as-you-go pricing (use ENABLE_WAF=true instead).
CLOUDFRONT_WEB_ACL_ID=
