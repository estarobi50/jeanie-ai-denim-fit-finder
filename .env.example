ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Shared token the frontend sends on /api/claude calls, checked server-side.
# Not a real secret (it ships in the client JS bundle) — it just raises the
# bar against naive bots hitting the endpoint without ever loading the page.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
JEANIE_SITE_KEY=REPLACE_WITH_RANDOM_VALUE
REACT_APP_JEANIE_SITE_KEY=REPLACE_WITH_SAME_RANDOM_VALUE
